{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "typescript", "unicorn", "oxc", "vue"],
  "env": {
    "browser": true,
    "node": true
  },
  "categories": {
    "correctness": "error"
  },
  "ignorePatterns": ["dist/**", "es/**", "lib/**", "docs/**", "demo/**", "ai-docs/**"]
}
